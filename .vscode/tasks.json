{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "cmake: build + run",
            "group": "build",
            "osx": {
                "command": "cmake -B build && cmake --build build && ./build/src/app"
            },
            "windows": {
                "command": "cmake -B build && cmake --build build && && build\\Debug\\app.exe"
            }
        },
        {
            "label": "pdflatex",
            "type": "shell",
            "command": "cd docs\\rpz && set TEXINPUTS=bmstu\\; && pdflatex main.tex -output-directory=build && start build\\main.pdf",
            "problemMatcher": []
        },
        {
            "label": "biber",
            "type": "shell",
            "command": "cd docs\\rpz && biber --output-directory=build main",
            "problemMatcher": []
        },
        {
            "label": "all latex build",
            "type": "shell",
            "dependsOn": [
                "pdflatex",
                "biber",
                "pdflatex",
                "pdflatex"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}